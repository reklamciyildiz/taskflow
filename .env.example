# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# Google OAuth (Get these from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Calendar OAuth callback (must match an Authorized redirect URI in Google Cloud Console)
# Example: http://localhost:3000/api/integrations/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Encrypt Google refresh tokens at rest (32 bytes). Generate e.g.:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=your-32-byte-key-base64-or-hex

# Public URL used in calendar event descriptions (fallbacks exist, but set explicitly in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron: shared secret for /api/cron/* when not using Vercel Cron User-Agent.
# Production: set CRON_SECRET on Vercel (same value as below if you use GitHub cron).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
#
# CRON_BASE_URL is NOT a Next.js env var. Add it only in GitHub:
# Repo → Settings → Secrets and variables → Actions → New repository secret
#   Name:  CRON_BASE_URL
#   Value: https://your-production-domain.vercel.app   (no trailing slash)
# Plus CRON_SECRET there (same string as Vercel). See .github/workflows/scheduled-reminders-cron.yml

# Supabase Configuration
# Get these from your Supabase project settings
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (VAPID)
# Generate once (do NOT commit private key):
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@your-domain.com

# AI Features Configuration
# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# AI Feature Flags (true/false)
AI_FEATURES_ENABLED=false
AI_VOICE_TO_TASK_ENABLED=true
AI_DESCRIPTION_GENERATOR_ENABLED=true
AI_DAILY_STANDUP_ENABLED=true
AI_BLOCKER_DETECTOR_ENABLED=true

# AI Model Configuration
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_SPEECH_MODEL=whisper-1

